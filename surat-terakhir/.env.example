# ============================================
# Surat Terakhir — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# On Railway, set these in the Variables tab.

# --- Node ---
NODE_ENV=production
PORT=3000

# --- Auth ---
# Password for welcome page (default: PalingGayeng2026)
PASSWORD=PalingGayeng2026
# Random 32+ char secret for cookie signing. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=replace_with_random_32_char_hex_string

# --- AI Service (Google Gemini 2.5 Flash) ---
# Comma-separated API keys for round-robin. Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEYS=key1,key2,key3,key4,key5
# Disable AI (use seed only) for offline mode
AI_GENERATION_ENABLED=true
# Trigger auto-generation when fragmen pool below this count
AI_GENERATION_THRESHOLD=3
# Per-request timeout in milliseconds
AI_GENERATION_TIMEOUT_MS=30000

# --- Game Settings ---
SNAPSHOT_INTERVAL_MS=30000
MAX_PLAYERS_PER_ROOM=12
ROUND_DURATION_BACA_S=60
ROUND_DURATION_DISKUSI_S=240
ROUND_DURATION_VOTING_S=30

# --- Rate Limiting ---
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW_MS=300000

# --- Logging ---
LOG_LEVEL=info

# --- Public URL (auto-detect if not set) ---
# PUBLIC_URL=https://youthgame-palinggayeng-punkora.up.railway.app
