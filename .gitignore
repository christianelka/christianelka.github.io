# --- Sisyphus / Agent artifacts ---
.sisyphus/
.config/

# --- Playwright test artifacts ---
.playwright-mcp/
playwright-report/
test-results/

# --- nuke/ (Nursery rapor system) — exclude only sensitive/test/binary files ---
# Project source (.html, .css, .js) IS committed
# Binary documents (docx/xlsx) excluded to keep repo lean
nuke/**/*.docx
nuke/**/*.xlsx
nuke/API.txt
nuke/.htaccess
nuke/tests/
nuke/data/sample_*.js
nuke/data/xlsx.*.min.js

# --- OS files ---
Thumbs.db
.DS_Store
Desktop.ini
*.swp
*.swo
*~

# --- Editor / IDE ---
.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace

# --- PowerShell / install scripts ---
*.ps1
!build.ps1

# --- Backup files ---
*_backup.*
*_bak.*
* copy.*
*_copy.*
*.bak
*.backup

# --- Node.js / npm ---
# Root-level lockfiles ignored (this repo doesn't use Node at root)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
/package-lock.json
/yarn.lock
/pnpm-lock.yaml

# --- Env files ---
.env
.env.local
.env.*.local

# --- Laragon / local server ---
.htaccess

# --- Logs ---
*.log

# --- surat-terakhir/ runtime data (nested project) ---
# (project's own .gitignore in surat-terakhir/ handles its own data/ runtime files)
